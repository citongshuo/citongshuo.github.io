{
  "version": 1,
  "include": ["/*"],
  "exclude": ["/assets/*", "/img/*", "/js/*", "/css/*", "/*.html"],
  "headers": [
    {
      "path": "/*",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}